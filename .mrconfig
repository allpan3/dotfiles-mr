[DEFAULT]
jobs = 5

[$HOME/.config/vcsh/repo.d/mr.git]
checkout = vcsh clone git@github.com:allpan3/dotfiles-mr.git mr
update = vcsh mr pull --ff-only
push = vcsh mr push
status = vcsh mr -c color.status=always status -uno
diff = vcsh mr -c color.ui=always diff --color=always

[$HOME/.config/vcsh/repo.d/dot.git]
checkout = vcsh clone git@github.com:allpan3/dotfiles-main.git dot
update = vcsh dot pull --ff-only
push = vcsh dot push
status = vcsh dot -c color.status=always status -uno
diff = vcsh dot -c color.ui=always diff --color=always

[$HOME/.config/vcsh/repo.d/local.git]
checkout =
    set -eu
    branch="${DOTFILES_BRANCH:?Set DOTFILES_BRANCH first}"
    remote="git@github.com:allpan3/dotfiles-local.git"
    if git ls-remote --exit-code --heads "$remote" "$branch" >/dev/null 2>&1; then
        vcsh clone -b "$branch" "$remote" local
    else
        vcsh init local
        vcsh local remote add origin "$remote"
        vcsh local fetch origin || true
        vcsh local switch --orphan "$branch" 2>/dev/null || vcsh local checkout --orphan "$branch"
        vcsh local config status.showUntrackedFiles no
        echo "Created empty dotfiles-local branch: $branch"
    fi
update = vcsh local pull --ff-only
push = vcsh local push
status = vcsh local -c color.status=always status -uno
diff = vcsh local -c color.ui=always diff --color=always

[$HOME/.config/nvim]
checkout = git clone git@github.com:allpan3/nvim.git "$HOME/.config/nvim"
update = git pull --ff-only
push = git push
status = git -c color.status=always status
diff = git -c color.ui=always diff --color=always

