[DEFAULT]
jobs = 5

[$HOME/.config/vcsh/repo.d/mr.git]
checkout = vcsh clone git@github.com:allpan3/dotfiles-mr.git mr
update = vcsh mr pull --ff-only
push = vcsh mr push
status = vcsh mr status -uno
diff = vcsh mr diff

[$HOME/.config/vcsh/repo.d/dot.git]
checkout = vcsh clone git@github.com:allpan3/dotfiles.git dot
update = vcsh dot pull --ff-only
push = vcsh dot push
status = vcsh dot status -uno
diff = vcsh dot diff

[$HOME/.config/vcsh/repo.d/local.git]
checkout = 
	   branch="${DOTFILES_BRANCH:-mac}"
	   vcsh clone -b "$branch" git@github.com:allpan3/dotfiles-local.git local
update = vcsh local pull --ff-only
push = vcsh local push
status = vcsh local status -uno
diff = vcsh local diff

[$HOME/.config/nvim]
checkout = git clone git@github.com:allpan3/nvim.git "$HOME/.config/nvim"
update = git pull --ff-only
push = git push
status = git status -sb
diff = git diff

